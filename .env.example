# ============================================================
# OpenClaw Docker Compose 環境變數
# 複製此檔案為 .env 並修改：cp .env.example .env
# ============================================================

# [必填] Gateway 認證 Token（執行 openssl rand -hex 32 生成）
OPENCLAW_GATEWAY_TOKEN=

# [選填] Docker Image（預設使用官方最新版）
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# [選填] 資料持久化路徑（預設使用 Docker named volumes）
# OPENCLAW_CONFIG_DIR=/home/youruser/.openclaw
# OPENCLAW_WORKSPACE_DIR=/home/youruser/.openclaw/workspace

# [選填] Port 設定
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# [選填] Gateway 綁定地址（預設 127.0.0.1 僅本機存取）
# 設為 0.0.0.0 可從外部存取（不建議，請改用反向代理）
OPENCLAW_GATEWAY_BIND_ADDR=127.0.0.1
OPENCLAW_GATEWAY_BIND=lan

# ============================================================
# 安全設定
# ============================================================

# Sandbox 模式：non-main = 非主會話強制 sandbox
OPENCLAW_SANDBOX_MODE=non-main

# 限制檔案存取在 workspace 內
TOOLS_FS_WORKSPACEONLY=true

# 防 fork bomb：限制 PID 數量
AGENTS_DEFAULTS_SANDBOX_PIDS_LIMIT=256

# [選填] 允許不安全的私有 WebSocket（預設關閉）
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=true

# ============================================================
# LLM Provider API Keys（依需求填入，至少設定一組）
# ============================================================

# --- Cloud API Provider（擇一即可）---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx
# OPENROUTER_API_KEY=sk-or-xxxxx
# GEMINI_API_KEY=xxxxx

# --- Local LLM（vLLM / Ollama）---
# vLLM：預設端點 http://host.docker.internal:8000/v1
# VLLM_API_KEY=token-abc123

# Ollama：預設端點 http://host.docker.internal:11434
# OLLAMA_API_KEY=

# --- Claude Web Session（非 API，透過瀏覽器 session）---
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
